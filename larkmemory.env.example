# LarkMemory runtime configuration template.
# Copy to larkmemory.env and edit before starting the backend service.

# Backend bind address. Use 0.0.0.0 when running on a cloud server.
LARKMEMORY_HOST=127.0.0.1
LARKMEMORY_PORT=8765
LARKMEMORY_ENV=local
LARKMEMORY_DEBUG=false

# Client-facing API addresses.
# Python demo/benchmark/CLI/OpenClaw plugin use LARKMEMORY_API_BASE.
# Clients append /api/v1 internally when needed.
# Local mode:
LARKMEMORY_API_BASE=http://127.0.0.1:8765
# Cloud mode example:
# LARKMEMORY_HOST=0.0.0.0
# LARKMEMORY_API_BASE=http://<ALIYUN_PUBLIC_IP>:8765

LARKMEMORY_DATA_DIR=.larkmemory
LARKMEMORY_SQLITE_PATH=.larkmemory/larkmemory.db
LARKMEMORY_CHROMA_DIR=.larkmemory/chroma
LARKMEMORY_CHROMA_COLLECTION=memory_core
LARKMEMORY_LOG_LEVEL=INFO
LARKMEMORY_LOG_DIR=logs
LARKMEMORY_LOG_FILE=larkmemory.log
LARKMEMORY_REQUEST_LOG_ENABLED=true

LARKMEMORY_ENABLE_LLM=false
LARKMEMORY_LLM_API_KEY=
LARKMEMORY_LLM_MODEL=
LARKMEMORY_LLM_BASE_URL=
LARKMEMORY_LLM_TIMEOUT=60
LARKMEMORY_LLM_MAX_RETRIES=2

LARKMEMORY_ENABLE_EMBEDDING=false
LARKMEMORY_ENABLE_VECTOR_STORE=true
LARKMEMORY_EMBEDDING_PROVIDER=http
LARKMEMORY_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
LARKMEMORY_EMBEDDING_API_KEY=
LARKMEMORY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
LARKMEMORY_EMBEDDING_DIMENSIONS=1024
LARKMEMORY_EMBEDDING_ENCODING_FORMAT=float
LARKMEMORY_EMBEDDING_TIMEOUT=60
LARKMEMORY_EMBEDDING_MAX_RETRIES=2

LARKMEMORY_ENABLE_RERANK=false
LARKMEMORY_RERANK_PROVIDER=http
LARKMEMORY_RERANK_BASE_URL=http://127.0.0.1:8002
LARKMEMORY_RERANK_ENDPOINT=/rerank
LARKMEMORY_RERANK_API_KEY=
LARKMEMORY_RERANK_MODEL=bge-reranker-v2-m3
LARKMEMORY_RERANK_TIMEOUT=60

LARKMEMORY_ENABLE_PROACTIVE_PUSH=false
LARKMEMORY_PROACTIVE_DECIDER_MIN_CONFIDENCE=0.8
LARKMEMORY_PROACTIVE_RELATED_TOP_K=3
LARKMEMORY_PROACTIVE_MIN_RELATED_SCORE=0.55

LARKMEMORY_FEISHU_APP_ID=
LARKMEMORY_FEISHU_APP_SECRET=
LARKMEMORY_FEISHU_DEFAULT_CHAT_ID=
